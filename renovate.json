{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    ":dependencyDashboard",
    ":maintainLockFilesWeekly",
    ":semanticCommitTypeAll(chore)"
  ],
  "prConcurrentLimit": 0,
  "rangeStrategy": "update-lockfile",
  "commitBody": "Signed-off-by: renovate[bot] <29139614+renovate[bot]@users.noreply.github.com>",
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "baseBranchPatterns": [
    "main"
  ],
  "recreateWhen": "never",
  "timezone": "America/New_York",
  "packageRules": [
    {
      "groupName": "Python dependencies (minor and patch)",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "pyproject.toml"
      ],
      "schedule": [
        "before 7am on monday"
      ],
      "prPriority": 7
    },
    {
      "groupName": "Python dependencies (major)",
      "matchUpdateTypes": [
        "major"
      ],
      "matchFileNames": [
        "pyproject.toml"
      ],
      "schedule": [
        "after 7pm on thursday"
      ],
      "prPriority": 10
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchFileNames": [
        ".github/workflows/**"
      ],
      "schedule": [
        "before 6pm on wednesday"
      ],
      "prPriority": 5
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["quay.io/fedora/fedora"],
      "enabled": false
    }
  ]
}
